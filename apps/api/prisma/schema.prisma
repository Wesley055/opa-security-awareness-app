generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  RESPONDER
  ADMIN
  HOSPITAL_STAFF
}

enum IncidentStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  CANCELLED
}

enum IncidentTrigger {
  SOS_BUTTON
  VOICE_HELP_HELP
  TRUSTED_CONTACT
  SYSTEM_TEST
}

enum NotificationChannel {
  PUSH
  SMS
  WHATSAPP
  VOICE
  EMAIL
}

enum NotificationStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  ACKNOWLEDGED
  FAILED
  CANCELLED
}

enum FacilityType {
  HOSPITAL
  POLICE_STATION
  FIRE_STATION
  SECURITY_PROVIDER
  NGO
  GOVERNMENT_AGENCY
  OTHER
}

enum EvidenceType {
  AUDIO
  VIDEO
  IMAGE
  GPS_LOG
  DOCUMENT
}

enum EvidenceStatus {
  PENDING
  UPLOADING
  STORED
  FAILED
  DELETED
}

model User {
  id                String             @id @default(uuid()) @db.Uuid
  email             String             @unique
  phoneNumber       String             @unique
  passwordHash      String
  firstName         String
  lastName          String
  role              UserRole           @default(USER)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  incidents         Incident[]
  emergencyContacts EmergencyContact[]

  facilityId        String?            @db.Uuid
  facility          Facility?          @relation("FacilityStaff", fields: [facilityId], references: [id])

  @@index([phoneNumber])
  @@index([facilityId])
}

model Incident {
  id             String          @id @default(uuid()) @db.Uuid
  userId         String          @db.Uuid
  user           User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  trigger        IncidentTrigger
  status         IncidentStatus  @default(OPEN)
  latitude       Decimal         @db.Decimal(9, 6)
  longitude      Decimal         @db.Decimal(9, 6)
  address        String?
  voicePhrase    String?
  trustedContact Json?
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  resolvedAt     DateTime?

  facilityId     String?         @db.Uuid
  facility       Facility?       @relation(fields: [facilityId], references: [id])

  timelineEvents IncidentTimelineEvent[]
  notifications  IncidentNotification[]
  evidence       Evidence[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([facilityId, status])
}

model EmergencyContact {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName    String
  lastName     String
  relationship String
  phoneNumber  String
  email        String?
  isPrimary    Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model IncidentTimelineEvent {
  id            String   @id @default(uuid()) @db.Uuid
  incidentId    String   @db.Uuid
  incident      Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  sequence      Int
  type          String
  payload       Json?
  source        String
  actorUserId   String?  @db.Uuid
  correlationId String?

  occurredAt    DateTime
  recordedAt    DateTime @default(now())

  previousHash  String?
  hash          String

  @@unique([incidentId, sequence])
  @@index([incidentId, occurredAt])
  @@index([incidentId, type, occurredAt])
  @@index([correlationId])
}

model IncidentNotification {
  id                String              @id @default(uuid()) @db.Uuid
  incidentId        String              @db.Uuid
  incident          Incident            @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  contactId         String?             @db.Uuid
  contactName       String
  contactType       String
  recipient         String
  channel           NotificationChannel
  status            NotificationStatus

  provider          String?
  providerMessageId String?
  attemptCount      Int                 @default(0)
  lastError         String?
  payload           Json?

  queuedAt          DateTime            @default(now())
  sentAt            DateTime?
  deliveredAt       DateTime?
  acknowledgedAt    DateTime?
  failedAt          DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([incidentId, queuedAt])
  @@index([status, queuedAt])
  @@index([providerMessageId])
}

model Facility {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  type        FacilityType
  address     String?
  phoneNumber String?
  latitude    Decimal?     @db.Decimal(9, 6)
  longitude   Decimal?     @db.Decimal(9, 6)
  isVerified  Boolean      @default(false)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  staff       User[]       @relation("FacilityStaff")
  incidents   Incident[]

  @@index([type, isActive])
  @@index([latitude, longitude])
}

model Evidence {
  id              String         @id @default(uuid()) @db.Uuid
  incidentId      String         @db.Uuid
  incident        Incident       @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  type            EvidenceType
  status          EvidenceStatus @default(PENDING)
  storageKey      String?
  mimeType        String?
  sizeBytes       BigInt?
  sha256          String?
  encryptionKeyId String?

  capturedAt      DateTime?
  uploadedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([incidentId, createdAt])
  @@index([status, createdAt])
  @@unique([incidentId, sha256])
}